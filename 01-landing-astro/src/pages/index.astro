---
// Página de inicio — ensambla todos los componentes
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Pricing from '../components/Pricing.astro';
import Footer from '../components/Footer.astro';

import '../styles/global.css';
---

<Layout>
  <Header />
  <main>
    <Hero />
    <Features />
    <!--
      SECCIONES ADICIONALES POR AÑADIR:
      - HowItWorks (pasos con animación scroll)
      - Testimonials (carrusel o grid de reviews)
      - LogoCloud (logos de clientes / partners)
      - CtaBanner (llamada a acción final)
    -->
    <Pricing />
  </main>
  <Footer />
</Layout>
