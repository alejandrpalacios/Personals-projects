---
const plans = [
  {
    name: 'Starter', price: '$0',
    periodKey: 'plan-0-period', periodDefault: 'forever',
    descKey:   'plan-0-desc',   descDefault:   'For freelancers and small teams just getting started.',
    ctaKey:    'plan-0-cta',    ctaDefault:    'Start for free',
    featured: false,
    features: ['Up to 3 active projects', '5 team members', 'Kanban & list boards', '2 GB storage', 'Email support'],
  },
  {
    name: 'Pro', price: '$18',
    periodKey: 'plan-1-period', periodDefault: 'per user / month',
    descKey:   'plan-1-desc',   descDefault:   'For growing teams that need power and control.',
    ctaKey:    'plan-1-cta',    ctaDefault:    'Try 14 days free',
    featured: true,
    features: ['Unlimited projects', 'Unlimited members', 'AI automations', '50 GB storage', '+80 integrations', 'Advanced reports', 'Priority support'],
  },
  {
    name: 'Enterprise', price: 'Custom',
    periodKey: 'plan-2-period', periodDefault: 'contact sales',
    descKey:   'plan-2-desc',   descDefault:   'For organizations that require security and compliance.',
    ctaKey:    'plan-2-cta',    ctaDefault:    'Talk to sales',
    featured: false,
    features: ['Everything in Pro', 'SSO / SAML', 'Granular permissions', 'SLA 99.9%', 'Unlimited storage', 'Dedicated account manager'],
  },
];
---

<section class="pricing section" id="pricing">
  <div class="container">
    <div class="pricing__header">
      <span class="section__label" data-i18n="pricing.label">Pricing</span>
      <h2 class="section__title"  data-i18n="pricing.title">Choose the plan that scales with you</h2>
      <p class="section__subtitle" data-i18n="pricing.subtitle">No contracts. Cancel anytime.</p>
    </div>

    <div class="pricing__grid">
      {plans.map((plan, i) => (
        <article class={`pricing-card ${plan.featured ? 'pricing-card--featured' : ''}`}>
          {plan.featured && <span class="pricing-card__badge">Most popular</span>}

          <div class="pricing-card__header">
            <h3 class="pricing-card__name">{plan.name}</h3>
            <div class="pricing-card__price">
              <span class="price-amount">{plan.price}</span>
              <span class="price-period" data-i18n={plan.periodKey}>{plan.periodDefault}</span>
            </div>
            <p class="pricing-card__desc" data-i18n={plan.descKey}>{plan.descDefault}</p>
          </div>

          <a href="#" class={`btn ${plan.featured ? 'btn--primary' : 'btn--ghost'} btn--full`} data-i18n={plan.ctaKey}>
            {plan.ctaDefault}
          </a>

          <ul class="pricing-card__features" role="list">
            {plan.features.map(f => (
              <li class="feature-item">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8l3.5 3.5 6.5-7" stroke="#6366f1" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing__header { text-align: center; margin-bottom: var(--space-xl); }

  .pricing__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md);
    align-items: start;
  }

  .pricing-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    position: relative;
  }

  .pricing-card--featured {
    border-color: var(--color-primary);
    background: var(--color-surface-2);
    box-shadow: var(--shadow-glow);
    transform: scale(1.02);
  }

  .pricing-card__badge {
    position: absolute;
    top: -12px; left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.8rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .pricing-card__name   { font-size: 1rem; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .pricing-card__price  { display: flex; align-items: baseline; gap: 0.4rem; margin-top: 0.25rem; }
  .price-amount  { font-size: 2.4rem; font-weight: 800; letter-spacing: -0.03em; }
  .price-period  { font-size: 0.82rem; color: var(--color-text-muted); }
  .pricing-card__desc { font-size: 0.88rem; color: var(--color-text-muted); }

  .btn--full { width: 100%; justify-content: center; }

  .pricing-card__features { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; }
  .feature-item { display: flex; align-items: center; gap: 0.6rem; font-size: 0.88rem; }

  @media (max-width: 860px) {
    .pricing-card--featured { transform: none; }
  }
</style>
