---
// Sección hero — primera impresión del producto
---

<section class="hero section">
  <div class="container">
    <!-- Anuncio / novedad -->
    <div class="hero__announce">
      <span class="badge">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><circle cx="6" cy="6" r="6"/></svg>
        Nuevo — Integración con IA disponible
      </span>
    </div>

    <!-- Titular principal -->
    <h1 class="hero__title">
      Gestiona proyectos con<br />
      <span class="hero__title--accent">claridad total</span>
    </h1>

    <p class="hero__subtitle">
      TaskFlow centraliza tu equipo, automatiza el seguimiento de tareas
      y te da visibilidad en tiempo real para entregar proyectos sin caos.
    </p>

    <!-- CTAs -->
    <div class="hero__cta">
      <a href="#pricing" class="btn btn--primary">
        Empieza gratis — 14 días
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="#how-it-works" class="btn btn--ghost">
        Ver demo
      </a>
    </div>

    <!-- Prueba social rápida -->
    <p class="hero__social-proof">
      Más de <strong>2,400 equipos</strong> ya confían en TaskFlow — sin tarjeta de crédito
    </p>

    <!-- Placeholder del producto / screenshot -->
    <div class="hero__preview" aria-label="Vista previa del dashboard de TaskFlow">
      <div class="hero__preview-inner">
        <!-- Reemplazar con screenshot real del producto -->
        <div class="preview-placeholder">
          <span>[ Screenshot del producto ]</span>
          <p>Reemplazar con imagen real — recomendado: 1200×700 px</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--space-2xl) + 80px); /* compensa el header fijo */
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  /* Fondo con gradiente radial sutil */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(99, 102, 241, 0.18), transparent 70%);
    pointer-events: none;
  }

  .hero__announce {
    margin-bottom: var(--space-md);
  }

  .hero__title {
    font-size: clamp(2.2rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    max-width: 16ch;
    margin-inline: auto;
  }

  .hero__title--accent {
    /* Gradiente en el texto destacado */
    background: linear-gradient(135deg, #818cf8, #6366f1 50%, #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__subtitle {
    margin-top: var(--space-md);
    font-size: 1.15rem;
    color: var(--color-text-muted);
    max-width: 48ch;
    margin-inline: auto;
  }

  .hero__cta {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
    flex-wrap: wrap;
  }

  .hero__social-proof {
    margin-top: var(--space-md);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .hero__social-proof strong {
    color: var(--color-text);
  }

  /* Preview del producto */
  .hero__preview {
    margin-top: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    overflow: hidden;
    box-shadow: var(--shadow-card), var(--shadow-glow);
    position: relative;
  }

  /* Degradado superior del preview para difuminarlo */
  .hero__preview::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(99,102,241,0.5), transparent);
  }

  .hero__preview-inner {
    padding: var(--space-lg);
    min-height: 400px;
    display: grid;
    place-items: center;
  }

  .preview-placeholder {
    color: var(--color-text-muted);
    text-align: center;
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    width: 100%;
  }

  .preview-placeholder span {
    display: block;
    font-size: 1.2rem;
    margin-bottom: var(--space-xs);
  }

  .preview-placeholder p {
    font-size: 0.8rem;
    opacity: 0.6;
  }

  @media (max-width: 600px) {
    .hero__cta {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
