---
---

<section class="hero section">
  <div class="container">
    <div class="hero__announce">
      <span class="badge">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><circle cx="6" cy="6" r="6"/></svg>
        <span data-i18n="hero.badge">New — AI integration available</span>
      </span>
    </div>

    <h1 class="hero__title">
      <span data-i18n="hero.title-1">Manage projects with</span><br />
      <span class="hero__title--accent" data-i18n="hero.title-2">total clarity</span>
    </h1>

    <p class="hero__subtitle" data-i18n="hero.subtitle">
      TaskFlow centralizes your team, automates task tracking, and gives you real-time visibility to deliver projects without chaos.
    </p>

    <div class="hero__cta">
      <a href="#pricing" class="btn btn--primary">
        <span data-i18n="hero.cta-1">Start free — 14 days</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="#how-it-works" class="btn btn--ghost" data-i18n="hero.cta-2">Watch demo</a>
    </div>

    <!-- data-i18n-html porque contiene <strong> -->
    <p class="hero__social-proof" data-i18n-html="hero.proof">
      More than <strong>2,400 teams</strong> already trust TaskFlow — no credit card required
    </p>

    <div class="hero__preview" aria-label="TaskFlow dashboard preview">
      <div class="hero__preview-inner">
        <div class="preview-placeholder">
          <span>[ Product screenshot ]</span>
          <p>Replace with real image — recommended: 1200×700 px</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--space-2xl) + 80px);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(99, 102, 241, 0.18), transparent 70%);
    pointer-events: none;
  }

  .hero__announce { margin-bottom: var(--space-md); }

  .hero__title {
    font-size: clamp(2.2rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    max-width: 16ch;
    margin-inline: auto;
  }

  .hero__title--accent {
    background: linear-gradient(135deg, #818cf8, #6366f1 50%, #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__subtitle {
    margin-top: var(--space-md);
    font-size: 1.15rem;
    color: var(--color-text-muted);
    max-width: 48ch;
    margin-inline: auto;
  }

  .hero__cta {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
    flex-wrap: wrap;
  }

  .hero__social-proof {
    margin-top: var(--space-md);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .hero__preview {
    margin-top: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    overflow: hidden;
    box-shadow: var(--shadow-card), var(--shadow-glow);
    position: relative;
  }

  .hero__preview::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(99,102,241,0.5), transparent);
  }

  .hero__preview-inner { padding: var(--space-lg); min-height: 400px; display: grid; place-items: center; }

  .preview-placeholder {
    color: var(--color-text-muted);
    text-align: center;
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    width: 100%;
  }

  .preview-placeholder span { display: block; font-size: 1.2rem; margin-bottom: var(--space-xs); }
  .preview-placeholder p    { font-size: 0.8rem; opacity: 0.6; }

  @media (max-width: 600px) {
    .hero__cta { flex-direction: column; align-items: center; }
  }
</style>
